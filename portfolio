  desc:"Full-spectrum design for an ed-tech institute across two Delhi branches — admission campaigns, course marketing, festival creatives, plus every piece of physical collateral: sign boards, hoardings and standees. Consistent, high-contrast work that lifted engagement ~30%.",
  link:"https://www.instagram.com/technokaksha",linkLabel:"View Instagram",
  cats:["social","signs","hoard","stand"], masonry:["signs"]}
];
const PROCESS=[
 ["01","Discover","Understand the brand, the audience and what the piece needs to do — before opening any tool."],
 ["02","Concept","Sketch directions, pull references and settle on the one visual idea worth building."],
 ["03","Design","Build in Photoshop, Illustrator or Canva, layering AI-assisted production where it earns its place."],
 ["04","Refine","Tighten type, colour and composition against the brand's existing visual language."],
 ["05","Deliver","Export, size and publish for the right channel — captioned and ready to perform."]
];
const QUOTES=[
 ["Seema turns a rough brief into a finished visual that feels premium every single time. Our lighting projects finally look the way they deserve to online.","Brand & Marketing","MR. Light Illumination"],
 ["Reliable, fast and genuinely creative. She owns our LinkedIn presence end-to-end and the consistency shows in our reach.","Founder","Opiniox MR"],
 ["Her admission and course creatives lifted our engagement noticeably. Students actually stop and read the posts now.","Academy Team","Techno Kaksha"]
];

/* ---------- RENDER ---------- */
document.getElementById("heroImg").src=IMG.mrl_spotlight;
document.getElementById("yr").textContent=new Date().getFullYear();

document.getElementById("skillsGrid").innerHTML=SKILLS.map(([n,c,l])=>
 `<div class="skill reveal"><span class="sw" style="background:${c}"></span><span class="nm">${n}</span><span class="lv">${l}</span></div>`).join("");

document.getElementById("timeline").innerHTML=EXPERIENCE.map(e=>
 `<div class="tl-item reveal"><span class="node"></span>
   <div class="tl-top"><span class="tl-role">${e.role}</span><span class="tl-time">${e.time}</span></div>
   <div class="tl-org">${e.org}</div>
   <ul class="tl-points">${e.points.map(p=>`<li>${p}</li>`).join("")}</ul></div>`).join("");

function tile2(m){return `<figure class="tile2" data-k="${m.k}" data-t="${m.t.replace(/"/g,'&quot;')}" data-cat="${CAT_LABEL[m.c]}" tabindex="0" role="button" aria-label="Enlarge ${m.t.replace(/"/g,'&quot;')}">
   <img src="${IMG[m.k]}" alt="${m.t.replace(/"/g,'&quot;')}" loading="lazy" width="${m.w}" height="${m.h}">
   <span class="exp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg></span>
   <figcaption class="cap"><span class="tt">${m.t}</span></figcaption></figure>`;}

function catBlock(cat,masonry){
  const items=META.filter(m=>m.c===cat);
  const inner=items.map(tile2).join("");
  const cls=masonry?`gal-m ${cat}`:`gal ${cat}`;
  return `<div class="catbar reveal"><span class="ct">${CAT_NAME[cat]}</span><span class="cn">${String(items.length).padStart(2,"0")}</span><span class="rule"></span></div>
   <div class="${cls} reveal">${inner}</div>`;
}

document.getElementById("projectsList").innerHTML=BRANDS.map(b=>{
 const cats=b.cats.map(c=>catBlock(c,b.masonry.includes(c))).join("");
 return `<div class="brand-block">
   <div class="brand-head reveal">
     <div class="bn">${b.num}</div>
     <div><h3>${b.name}</h3><div class="role">${b.role}</div><p>${b.desc}</p>
       <a class="proj-link" href="${b.link}" target="_blank" rel="noopener">${b.linkLabel}
         <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg></a></div>
   </div>${cats}</div>`;
}).join("")
+`<div class="brand-block"><div class="brand-head reveal">
   <div class="bn">03</div>
   <div><h3>Opiniox MR</h3><div class="role">Freelance Graphic Designer & Social Media Manager</div>
     <p>Freelance brand partner handling LinkedIn-first branding, corporate creatives, infographics and marketing graphics on a monthly content calendar.</p>
     <a class="proj-link" href="https://www.linkedin.com/company/opinioxmr/" target="_blank" rel="noopener">View LinkedIn
       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg></a></div>
 </div>
 <div style="max-width:520px"><div class="specimen reveal">
   <div class="sp-top"><span>OPINIOX MR</span><span>LINKEDIN · CORPORATE</span></div>
   <div class="sp-mid">Corporate <b>creatives</b> &amp; infographics, on a monthly calendar.</div>
   <div class="sp-bot"><i>Brand System</i><i>Carousels</i><i>Reports</i><i>Motion</i></div>
 </div><div class="specimen-note">↳ Client work under NDA — samples on request</div></div></div>`;

document.getElementById("procGrid").innerHTML=PROCESS.map(([n,t,d])=>
 `<div class="proc-step"><div class="pn">${n}</div><h4>${t}</h4><p>${d}</p></div>`).join("");

document.getElementById("quotes").innerHTML=QUOTES.map(([q,n,r])=>
 `<div class="quote reveal"><div class="mark">"</div><p>${q}</p><div class="who"><span class="nm">${n}</span><span class="rl">${r}</span></div></div>`).join("");

/* ---------- INTERACTIONS ---------- */
// theme
const root=document.documentElement, tbtn=document.getElementById("themeBtn");
const sun='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="4.5"/><path d="M12 1.5v3M12 19.5v3M4.2 4.2l2 2M17.8 17.8l2 2M1.5 12h3M19.5 12h3M4.2 19.8l2-2M17.8 6.2l2-2"/></svg>';
const moon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>';
function setTheme(t){root.setAttribute("data-theme",t);tbtn.innerHTML=t==="dark"?moon:sun;}
setTheme("dark");
tbtn.onclick=()=>setTheme(root.getAttribute("data-theme")==="dark"?"light":"dark");

// nav scroll state
const header=document.getElementById("header");
addEventListener("scroll",()=>header.classList.toggle("scrolled",scrollY>30),{passive:true});

// mobile menu
const mobile=document.getElementById("mobile");
document.getElementById("burger").onclick=()=>{mobile.classList.add("open");document.body.style.overflow="hidden";};
const closeM=()=>{mobile.classList.remove("open");document.body.style.overflow="";};
document.getElementById("closeMenu").onclick=closeM;
mobile.querySelectorAll("a").forEach(a=>a.onclick=closeM);

// reveal on scroll
const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target);}}),{threshold:.12});
document.querySelectorAll(".reveal").forEach((el,i)=>{el.style.transitionDelay=(Math.min(i%6,5)*60)+"ms";io.observe(el);});

// cursor light (fine pointers)
const cur=document.getElementById("cursor");
if(matchMedia("(hover:hover) and (pointer:fine)").matches){
 addEventListener("mousemove",e=>{cur.style.left=e.clientX+"px";cur.style.top=e.clientY+"px";});
 const grow=sel=>document.querySelectorAll(sel).forEach(el=>{el.addEventListener("mouseenter",()=>cur.classList.add("big"));el.addEventListener("mouseleave",()=>cur.classList.remove("big"));});
 setTimeout(()=>grow("a,button,.tile,.tile2,.skill,.quote"),200);
}

// lightbox
const lb=document.getElementById("lightbox"),lbImg=document.getElementById("lbImg"),lbCap=document.getElementById("lbCap"),lbCat=document.getElementById("lbCat");
function openLB(k,t,cat){lbImg.src=IMG[k];lbImg.alt=t;lbCap.textContent=t;lbCat.textContent=cat;lb.classList.add("open");document.body.style.overflow="hidden";}
function closeLB(){lb.classList.remove("open");document.body.style.overflow="";}
document.getElementById("lbClose").onclick=closeLB;
lb.onclick=e=>{if(e.target===lb)closeLB();};
addEventListener("keydown",e=>{if(e.key==="Escape")closeLB();});
document.addEventListener("click",e=>{const t=e.target.closest(".tile,.tile2");if(t)openLB(t.dataset.k,t.dataset.t,t.dataset.cat);});
document.addEventListener("keydown",e=>{if((e.key==="Enter"||e.key===" ")&&(document.activeElement.classList.contains("tile")||document.activeElement.classList.contains("tile2"))){e.preventDefault();const t=document.activeElement;openLB(t.dataset.k,t.dataset.t,t.dataset.cat);}});
</script>
</body>
</html>
